        }
      ]
    },
    {
      "name": "保存確認ダイアログ - キャンセルを選択して操作取消",
      "steps": [
        {
          "action": "click",
          "target": { "name": "画面(S)" },
          "description": "画面メニューをクリック"
        },
        {
          "action": "click",
          "target": { "name": "メッセージ(M)" },
          "description": "メッセージメニューをクリック"
