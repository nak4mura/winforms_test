    },
    {
      "name": "バリデーション - 空入力でエラーダイアログ表示",
      "steps": [
        {
          "action": "click",
          "target": { "name": "画面(S)" },
          "description": "画面メニューをクリック"
        },
        {
          "action": "click",
          "target": { "name": "メッセージ(M)" },
          "description": "メッセージメニューをクリック"
        },
        {
          "action": "waitForWindow",
          "windowTitle": "メッセージ",
          "description": "メッセージ画面が表示されるまで待機"
        },
        {
          "action": "click",
          "target": { "automationId": "BtnValidation" },
          "description": "入力値が空のままバリデーションボタンをクリック"
        },
        {
          "action": "waitForWindow",
          "windowTitle": "入力エラー",
          "timeoutMs": 3000,
          "description": "入力エラーダイアログが表示されるまで待機"
        },
        {
          "action": "click",
          "target": { "name": "OK" },
          "description": "OKボタンをクリックしてエラーダイアログを閉じる"
        },
        {
          "action": "switchWindow",
          "windowTitle": "メッセージ",
          "description": "メッセージ画面に戻る"
        },
        {
          "action": "assert",
          "target": { "automationId": "LblMessageResult" },
          "expect": {
            "property": "Name",
            "operator": "contains",
            "value": "バリデーションエラー"
          },
          "description": "結果ラベルに「バリデーションエラー」が表示されていることを確認"
        }
      ]
    },
    {
      "name": "バリデーション - 入力ありで成功（ダイアログなし）",
      "steps": [
        {
          "action": "click",
          "target": { "name": "画面(S)" },
          "description": "画面メニューをクリック"
        },
        {
          "action": "click",
          "target": { "name": "メッセージ(M)" },
          "description": "メッセージメニューをクリック"
        },
        {
          "action": "waitForWindow",
          "windowTitle": "メッセージ",
          "description": "メッセージ画面が表示されるまで待機"
        },
        {
          "action": "type",
          "target": { "automationId": "TxtMessageInput" },
          "text": "テスト値",
          "description": "入力欄に「テスト値」を入力"
        },
        {
          "action": "click",
          "target": { "automationId": "BtnValidation" },
          "description": "バリデーションボタンをクリック"
        },
        {
          "action": "wait",
          "ms": 300,
          "description": "バリデーション処理完了を待機"
        },
        {
          "action": "assert",
          "target": { "automationId": "LblMessageResult" },
          "expect": {
            "property": "Name",
